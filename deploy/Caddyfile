# Apartment-building reverse proxy. Caddy auto-provisions a Let's Encrypt cert
# the first time each domain is hit — DNS must already point at this VM AND
# ports 80/443 must be reachable from the public internet (they are).
#
# Hosts served from this Caddy:
#   - fridge-chatbot.duckdns.org              → public app (frontend + backend + livekit)
#   - smagowski-ai-lab-langfuse.duckdns.org   → operator-only Langfuse UI
#                                                (self-signup disabled, single admin user)
#   - imported from /etc/caddy/conf.d/*.caddy — each new app drops its own
#     host block here (mounted from /srv/apps/<app>/Caddyfile.<app> via the
#     fridge-chatbot caddy container's volumes). See bottom of file.
#
# Operator-access policy: web-first via the dedicated duckdns hostname above.
# Do NOT propose `gcloud ... -L 3001:langfuse-web:3000` SSH-tunnel access as
# the default flow — that policy was retired 2026-05-11.

fridge-chatbot.duckdns.org {
    # LiveKit WebSocket signaling — reverse-proxied so clients talk over the
    # canonical HTTPS domain. The LiveKit JS client appends /rtc/v1 to whatever
    # serverUrl it receives from the backend, so the path Caddy strips is the
    # /livekit-ws prefix we configure in fetch-secrets.sh's LIVEKIT_PUBLIC_URL.
    handle_path /livekit-ws/* {
        reverse_proxy livekit-server:7880
    }

    # Backend handles the FastAPI surface.
    @backend path /api/* /oauth/* /threads /threads/* /users/* /health /ws/*
    reverse_proxy @backend fridge-backend:8001

    # Everything else → Next.js frontend.
    reverse_proxy fridge-frontend:3000

    # Sensible defaults.
    encode zstd gzip
    log {
        output stdout
        format console
    }
}

# Langfuse operator UI. Caddy auto-issues a Let's Encrypt cert on first hit.
# All paths (including the websocket-based /api/auth flow) go to one upstream.
# Self-signup is disabled inside Langfuse (AUTH_DISABLE_SIGNUP=true in compose);
# only the admin user seeded by LANGFUSE_INIT_USER_* can sign in.
smagowski-ai-lab-langfuse.duckdns.org {
    reverse_proxy langfuse-web:3000

    encode zstd gzip
    log {
        output stdout
        format console
    }
}

# Plain-HTTP requests to the bare IP (no Host match) still get a friendly
# redirect to the canonical HTTPS domain of the public app. Caddy's automatic
# HTTPS does this for matched hosts, but a request to http://<ip>/ wouldn't
# otherwise match any block above.
:80 {
    redir https://fridge-chatbot.duckdns.org{uri} permanent
}

# ---- Per-app host blocks (one file per app, dropped in conf.d) -------------
# Each new app on the apartment VM contributes its own host block under
# /etc/caddy/conf.d/<app>.caddy. The mount is configured per-app in this
# compose: `caddy.volumes += /srv/apps/<app>/Caddyfile.<app>:/etc/caddy/conf.d/<app>.caddy:ro`.
# Caddy reloads via SIGUSR1 inside the container; deploy.sh handles that.
import /etc/caddy/conf.d/*.caddy
