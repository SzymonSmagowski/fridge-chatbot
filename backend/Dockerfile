# Multi-stage build per the Poetry FAQ pattern
# (https://python-poetry.org/docs/faq/#poetry-busts-my-docker-cache).
#
# Stage 1 (builder) installs deps into a venv that we copy into the runtime
# stage. Runtime image has no Poetry, no build-essential, no apt cache —
# only what's needed to run uvicorn.
#
# Why Poetry 2.4.0: the committed poetry.lock was generated by Poetry 2.4.0;
# older Poetry refuses to install from it with
# "pyproject.toml changed significantly since poetry.lock was last generated".
# Keep this pin in lockstep with the devcontainer's Poetry version.

ARG PYTHON_VERSION=3.11-slim
ARG POETRY_VERSION=2.4.0

FROM python:${PYTHON_VERSION} AS builder
ARG POETRY_VERSION

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    POETRY_VIRTUALENVS_IN_PROJECT=1 \
    POETRY_NO_INTERACTION=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install "poetry==${POETRY_VERSION}"

WORKDIR /app
COPY pyproject.toml poetry.lock ./
# --no-root: don't try to install the project itself (package-mode = false).
# --no-directory: skip path-dependency installs (we have none, but it future-proofs).
RUN poetry install --only main --no-root --no-directory

# ---- Runtime stage ----------------------------------------------------------
FROM python:${PYTHON_VERSION} AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH"

# libpq5 for psycopg, postgresql-client for the entrypoint health checks /
# alembic upgrade. No build-essential here — that lives in the builder stage.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libpq5 \
        postgresql-client \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/.venv /app/.venv
COPY . .

RUN useradd -m -u 1000 -s /bin/bash appuser \
    && chown -R appuser:appuser /app
USER appuser

EXPOSE 8001

COPY --chown=appuser:appuser docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh
ENTRYPOINT ["docker-entrypoint.sh"]
