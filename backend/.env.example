# OpenAI
OPENAI_API_KEY=
DEFAULT_MODEL=gpt-5.4-nano
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1000

# Postgres — defaults match the devcontainer sidecar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
SQL_ECHO=false

# Redis — used for cache-aside, pub/sub, slowapi storage, OAuth state
REDIS_URL=redis://redis:6379

# Encryption (Fernet) — used to encrypt Google refresh tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=v3wPLJTw45A9mE_b6mIwS5zmpxwPF-43bp9xL9qsQT4=

# JWT
SECRET_KEY=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60480
DEVICE_TOKEN_EXPIRE_DAYS=365
BACKEND_DEBUG_API_KEY=

# Bootstrap defaults — written into family_preferences on pairing.
AUTO_CREATE_SHOPPING_LIST_DEFAULT=true
SYNC_INTERVAL_SEC_DEFAULT=300

# Google OAuth — required for the calendar feature.
# Create OAuth client (web application) in Google Cloud Console; add the
# redirect URI below to its allow-list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/oauth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/calendar

# Frontend base URL — OAuth callback redirects need an absolute target since
# the backend (8001) and frontend (3000) run on different origins.
FRONTEND_BASE_URL=http://localhost:3000

# Local diagnostic — when true, logs CPU%/RSS/threads/fd-count every N seconds.
# Off in production; flip to true when debugging perf locally.
BACKEND_RESOURCE_MONITOR=true
BACKEND_RESOURCE_MONITOR_INTERVAL_SECONDS=5.0

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Langfuse v3 — defaults match the devcontainer sidecar with auto-provisioned keys.
# In production, replace these with keys from your Langfuse instance.
LANGFUSE_PUBLIC_KEY=pk-lf-dev-0000000000000000000000000000
LANGFUSE_SECRET_KEY=sk-lf-dev-0000000000000000000000000000
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_ENABLED=true

LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=fridge-chatbot
