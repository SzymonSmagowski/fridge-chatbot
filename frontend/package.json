{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy localStorage cookie globalVariable baseLocale",
    "dev": "pnpm run paraglide:compile && next dev",
    "build": "pnpm run paraglide:compile && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "pnpm run paraglide:compile && vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm run paraglide:compile && vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.25",
    "@assistant-ui/react-markdown": "^0.12.9",
    "@base-ui/react": "^1.4.0",
    "@inlang/paraglide-js": "^2.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.10",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "msw": "^2.13.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
